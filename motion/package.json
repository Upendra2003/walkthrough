{
  "name": "walkthrough-motion",
  "version": "1.0.0",
  "description": "Motion graphics for Walkthrough VS Code extension",
  "scripts": {
    "studio": "remotion studio src/index.ts",
    "preview": "ts-node -r tsconfig-paths/register preview.ts",
    "render": "remotion render src/index.ts CodeExplainer output/sample.mp4"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@remotion/bundler": "4.0.448",
    "@remotion/cli": "4.0.448",
    "@remotion/renderer": "4.0.448",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "remotion": "4.0.448",
    "tsconfig-paths": "^4.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0"
  }
}
